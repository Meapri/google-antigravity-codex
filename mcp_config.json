{
  "mcpServers": {
    "google-antigravity-codex": {
      "command": "python3",
      "args": [
        "${extensionPath}/scripts/google_antigravity_mcp.py"
      ],
      "cwd": "${extensionPath}",
      "env": {
        "GOOGLE_ANTIGRAVITY_RUNNING_UNDER_AGY": "1"
      },
      "disabledTools": [
        "google_antigravity_cli_status",
        "google_antigravity_cli_chat"
      ]
    }
  }
}
